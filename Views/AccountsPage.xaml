<Page x:Class="GithubManager.Views.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:GithubManager"
      xmlns:c="clr-namespace:GithubManager.Converters"
      Background="{StaticResource BgBrush}">
    <Page.DataContext>
        <Binding Source="{x:Static vm:App.AccountsVm}"/>
    </Page.DataContext>
    <Page.Resources>
        <c:InverseBoolConverter x:Key="InverseBoolConv"/>
        <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <c:ErrorToColorConverter x:Key="ErrorToColor"/>
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="900">
            <TextBlock Text="账号管理" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="添加 GitHub 账号（Personal Access Token）" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="用户名（可任意填，校验后会替换为 GitHub login）" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox Text="{Binding LoginInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>

                    <TextBlock Text="Personal Access Token" Foreground="{StaticResource MutedBrush}"/>
                    <PasswordBox x:Name="TokenBox" Margin="0,4,0,8" PasswordChanged="TokenBox_PasswordChanged"/>

                    <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,8">
                        Token 需要 scopes：repo、delete_repo。
                        <Hyperlink NavigateUri="https://github.com/settings/tokens?type=beta" RequestNavigate="OpenLink">
                            点击这里创建 Fine-grained token
                        </Hyperlink>
                    </TextBlock>

                    <Button Content="添加账号" Command="{Binding AddAccountCommand}" HorizontalAlignment="Left"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConv}}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="已保存的账号" Style="{StaticResource SectionHeader}"/>
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12" Margin="0,4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <Image Source="{Binding AvatarUrl}" Width="36" Height="36" Margin="0,0,12,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Login}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TokenTarget}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="切换" Command="{Binding DataContext.SwitchAccountCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}" Margin="4,0"/>
                                    <Button Content="删除" Command="{Binding DataContext.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}" Margin="4,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 状态提示 -->
            <Border Style="{StaticResource StatusBanner}"
                    Background="{Binding IsError, Converter={StaticResource ErrorToColor}}"
                    Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <DockPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <Button Content="详情" DockPanel.Dock="Right" Click="ShowTechDetail_Click"
                            Visibility="{Binding TechnicalDetail, Converter={StaticResource BoolToVis}}"
                            Background="#33000000" Foreground="White" Padding="8,2"/>
                </DockPanel>
            </Border>

            <TextBox Text="{Binding TechnicalDetail}" IsReadOnly="True" Visibility="Collapsed"
                     x:Name="TechDetailBox" Background="#1A1A1A" Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" MaxHeight="200" Margin="4"/>
        </StackPanel>
    </ScrollViewer>
</Page>
